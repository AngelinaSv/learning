// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Users {
  id          Int       @id @default(autoincrement()) @map("id")
  username    String    @unique @map("username")
  password    String    @map("password")
  email       String    @unique @map("email")
  isBanned    Boolean   @default(false) @map("is_banned")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  banEndAt    DateTime? @map("ban_end_at")
  role        Int       @default(1)
  lastLoginIP String?   @map("last_login_ip")
  lastLoginAt DateTime? @default(now()) @map("last_login_at")
  createdAt   DateTime? @default(now()) @map("created_at")
  updatedAt   DateTime? @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  profile Profiles?
  address Addresses?

  @@index([username])
  @@index([email])
  @@index([createdAt])
  @@index([lastLoginIP])
  @@map("user")
}

model Profiles {
  userId    Int      @id @map("user_id")
  addressId Int?     @unique
  rating    Int      @map("rating")
  balance   Decimal  @default(0) @map("balance") @db.Decimal(18, 6)
  avatar    String?  @map("avatar")
  level     Int      @default(0) @map("level")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user    Users      @relation(fields: [userId], references: [id])
  address Addresses? @relation(fields: [addressId], references: [userId])

  @@index([level])
  @@index([rating])
  @@map("profile")
}

model Addresses {
  userId      Int      @id @map("user_id")
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  phoneNumber String   @map("phone_number")
  address     String   @map("address")
  address2    String?  @map("address2")
  country     String?  @map("country")
  postalCode  String   @map("postal_code")
  city        String   @map("city")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user    Users     @relation(fields: [userId], references: [id])
  profile Profiles?

  @@index([country])
  @@index([city])
  @@map("address")
}

model GameSession {
  id         String   @id @default(uuid())
  userId     Int
  serverSeed String
  serverHash String
  clientSeed String
  nonce      Int      @default(0)
  createdAt  DateTime @default(now())

  bets RouletteBet[]
}

model RouletteBet {
  id            String      @id @default(uuid())
  gameId        String
  betType       String
  betAmount     Int
  winningNumber Int
  payoutAmount  Int
  isWin         Boolean
  nonce         Int
  createdAt     DateTime    @default(now())
  gameSession   GameSession @relation(fields: [gameId], references: [id])
}

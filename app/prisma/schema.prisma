// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

model User {
  id          String    @id @default(uuid())
  username    String    @unique @map("username")
  password    String    @map("password")
  email       String    @unique @map("email")
  isBanned    Boolean   @default(false) @map("is_banned")
  isDeleted   Boolean   @default(false) @map("is_deleted")
  banEndAt    DateTime? @map("ban_end_at")
  role        Role      @default(USER)
  lastLoginIP String?   @map("last_login_ip")
  lastLoginAt DateTime? @default(now()) @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  profile      Profile?
  addresses    Address[]
  gameSessions GameSession[]

  @@index([username])
  @@index([email])
  @@index([createdAt])
  @@index([lastLoginIP])
  @@map("users")
}

model Profile {
  userId    String   @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  rating    Int      @map("rating")
  balance   Decimal  @default(0) @map("balance") @db.Decimal(18, 6)
  avatar    String?  @map("avatar")
  level     Int      @default(0) @map("level")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([level])
  @@index([rating])
  @@map("profiles")
}

model Address {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  user        User     @relation(fields: [userId], references: [id])
  firstName   String   @map("first_name")
  lastName    String   @map("last_name")
  phoneNumber String   @map("phone_number")
  address     String   @map("address")
  address2    String?  @map("address2")
  country     String?  @map("country")
  postalCode  String   @map("postal_code")
  city        String   @map("city")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([country])
  @@index([city])
  @@map("addresses")
}

model GameSession {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  user       User     @relation(fields: [userId], references: [id])
  serverSeed String   @map("server_seed")
  serverHash String   @map("server_hash")
  clientSeed String   @map("client_seed")
  nonce      Int      @default(0)
  createdAt  DateTime @default(now()) @map("created_at")

  bets RouletteBet[]

  @@index([userId])
  @@map("game_sessions")
}

model RouletteBet {
  id            String      @id @default(uuid())
  gameId        String      @map("game_id")
  betType       String      @map("bet_type")
  betAmount     Int         @map("bet_amount")
  winningNumber Int         @map("winning_number")
  payoutAmount  Int         @map("payout_amount")
  isWin         Boolean     @map("is_win")
  nonce         Int
  createdAt     DateTime    @default(now()) @map("created_at")
  gameSession   GameSession @relation(fields: [gameId], references: [id])

  @@index([gameId])
  @@map("roulette_bets")
}
